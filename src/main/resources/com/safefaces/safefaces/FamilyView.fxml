<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefWidth="400.0"
            prefHeight="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.FamilyController">

    <children>

        <!-- Bakgrundsbild -->
        <ImageView fitWidth="400.0"
                   fitHeight="700.0"
                   preserveRatio="false">
            <image>
                <Image url="@images/family_green.png"/>
            </image>
        </ImageView>

        <!-- Tillbaka-knapp -->
        <Button fx:id="backButton"
                layoutX="5.0"
                layoutY="5.0"
                prefWidth="70.0"
                prefHeight="70.0"
                onAction="#goBack"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <!-- Röst/lyssna-knapp -->
        <Button fx:id="listenButton"
                layoutX="325.0"
                layoutY="5.0"
                prefWidth="70.0"
                prefHeight="70.0"
                onAction="#readFamily"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

    </children>

</AnchorPane>