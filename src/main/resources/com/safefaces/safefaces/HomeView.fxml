<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="400.0"
            style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.MainController">
    <children>
        <BorderPane prefHeight="800.0" prefWidth="400.0"
                    AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">


        <!-- TEXT + LOGO -->
            <top>
                <VBox spacing="10">
                    <padding>
                        <Insets top="20" bottom="10"/>
                    </padding>
                    <fx:include source="components/TopBar.fxml"/>
                </VBox>
            </top>


            <!--  the primary pane that we will be changing instead of Views -->
            <center>
                <AnchorPane fx:id="contentArea"/>
            </center>


            <bottom>
                <AnchorPane fx:id="bottomContainer"
                            prefHeight="78.0"
                            minHeight="78.0"/>
            </bottom>
        </BorderPane>
    </children>
</AnchorPane>