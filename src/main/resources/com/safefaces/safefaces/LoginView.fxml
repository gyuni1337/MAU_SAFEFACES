<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="400.0"
            style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.LoginController">

    <children>
        <VBox alignment="CENTER" spacing="28.0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <padding><Insets left="40" right="40"/></padding>

            <!-- Title -->
            <Label text="SafeFaces" style="-fx-text-fill: #3a3a3a;">
                <font><Font name="System Bold" size="22"/></font>
            </Label>

            <!-- Face ID image (decorative) -->
            <VBox alignment="CENTER"
                  style="-fx-background-color: #e0e0e0; -fx-background-radius: 20;"
                  prefWidth="160" prefHeight="160" maxWidth="160" maxHeight="160">
                <ImageView fitWidth="160" fitHeight="160" preserveRatio="true">
                    <image><Image url="@images/face_id_simulation.png"/></image>
                </ImageView>
            </VBox>

            <!-- Status label -->
            <Label fx:id="statusLabel" text=""
                   style="-fx-text-fill: #e05555;" wrapText="true">
                <font><Font size="14"/></font>
            </Label>

            <!-- Login as User -->
            <Button text="Logga in som User"
                    onAction="#handleUserLogin"
                    maxWidth="280"
                    style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                           -fx-font-size: 16; -fx-padding: 12 20; -fx-background-radius: 12;"/>

            <!-- Login as Vårdgivare -->
            <Button text="Logga in som Vårdgivare"
                    onAction="#handleShowCaregiverLogin"
                    maxWidth="280"
                    style="-fx-background-color: white; -fx-text-fill: #3a3a3a;
                           -fx-font-size: 16; -fx-padding: 12 20; -fx-background-radius: 12;
                           -fx-border-color: #3a3a3a; -fx-border-radius: 12;"/>

            <!-- Caregiver login form (hidden until button pressed) -->
            <VBox fx:id="caregiverBox" alignment="CENTER" spacing="12"
                  visible="false" managed="false">
                <TextField fx:id="usernameField"
                           promptText="Användarnamn"
                           maxWidth="260"
                           style="-fx-font-size: 16; -fx-padding: 10;"/>
                <PasswordField fx:id="pinField"
                               promptText="PIN-kod"
                               maxWidth="260"
                               style="-fx-font-size: 16; -fx-padding: 10;"/>
                <Button text="Logga in"
                        onAction="#handleCaregiverSubmit"
                        maxWidth="260"
                        style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                               -fx-font-size: 16; -fx-padding: 10 20; -fx-background-radius: 12;"/>
            </VBox>

        </VBox>
    </children>
</AnchorPane>
