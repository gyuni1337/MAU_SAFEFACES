<?xml version="1.0" encoding="UTF-8"?>

<!-- Imports for layout, controls, images, and text -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    Login view layout.
    Handles user authentication via Face ID simulation and PIN input.

    Structure:
    - App title (SafeFaces)
    - Face ID simulation area
    - Status text (updated dynamically)
    - PIN login section (initially hidden)

    Controlled by LoginController.
-->
<AnchorPane prefHeight="700.0" prefWidth="400.0"
            style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.LoginController">

    <children>
        <!-- Main vertical layout centered in the screen -->
        <VBox alignment="CENTER" spacing="28.0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            <padding><Insets left="40" right="40"/></padding>

            <!-- Application title / logo text -->
            <Label text="SafeFaces" style="-fx-text-fill: #3a3a3a;">
                <font><Font name="System Bold" size="22"/></font>
            </Label>

            <!-- Face ID simulation area -->
            <VBox alignment="CENTER" spacing="8"
                  style="-fx-background-color: #e0e0e0; -fx-background-radius: 20;"
                  prefWidth="160" prefHeight="160" maxWidth="160" maxHeight="160">

                <ImageView fitWidth="160" fitHeight="160" preserveRatio="true">
                    <image><Image url="@images/face_id_simulation.png"/></image>
                </ImageView>
            </VBox>

            <!-- Status label updated dynamically (e.g., scanning, errors) -->
            <Label fx:id="statusLabel" text="Scanning face..."
                   style="-fx-text-fill: #555555;" wrapText="true">
                <font><Font size="16"/></font>
            </Label>

            <!-- PIN login section (hidden initially, shown if Face ID fails) -->
            <VBox fx:id="pinBox" alignment="CENTER" spacing="16">
                <!-- Input field for PIN code -->
                <PasswordField fx:id="pinField"
                               promptText="Ange PIN-kod"
                               maxWidth="220"
                               style="-fx-font-size: 18; -fx-padding: 10;"/>
                <!-- Button to submit PIN -->
                <Button text="Logga in"
                        onAction="#handlePinLogin"
                        maxWidth="220"
                        style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                               -fx-font-size: 16; -fx-padding: 10 20; -fx-background-radius: 12;"/>
            </VBox>

        </VBox>
    </children>
</AnchorPane>