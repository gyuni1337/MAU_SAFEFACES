<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="400.0"
            style="-fx-background-color: #f5f0e8;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.LoginController">
    <children>

        <!-- Decorative background -->
        <ImageView fitWidth="400" fitHeight="700" preserveRatio="false"
                   AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0">
            <image><Image url="@images/background.png"/></image>
        </ImageView>

        <!-- Login card — positioned in the content area below the header -->
        <VBox alignment="CENTER" spacing="16"
              AnchorPane.leftAnchor="24" AnchorPane.rightAnchor="24"
              AnchorPane.topAnchor="160" AnchorPane.bottomAnchor="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 24;
                     -fx-padding: 32 28 32 28;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 16, 0, 0, 4);">

            <!-- Face ID image -->
            <ImageView fitWidth="120" fitHeight="120" preserveRatio="true">
                <image><Image url="@images/face_id_simulation.png"/></image>
            </ImageView>

            <Label text="Välkommen till SafeFaces"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>

            <Label fx:id="statusLabel" text=""
                   wrapText="true"
                   style="-fx-text-fill: #c62828; -fx-font-size: 13;"/>

            <!-- User login button -->
            <Button text="Logga in som användare"
                    onAction="#handleUserLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1a6b3d; -fx-text-fill: white;
                           -fx-font-size: 16; -fx-font-weight: bold;
                           -fx-padding: 14; -fx-background-radius: 14; -fx-cursor: hand;"/>

            <!-- Caregiver login button -->
            <Button text="Logga in som vårdgivare"
                    onAction="#handleShowCaregiverLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a6b3d;
                           -fx-font-size: 16; -fx-font-weight: bold;
                           -fx-padding: 14; -fx-background-radius: 14;
                           -fx-border-color: #1a6b3d; -fx-border-radius: 14;
                           -fx-cursor: hand;"/>

            <!-- Caregiver form (toggled) -->
            <VBox fx:id="caregiverBox" alignment="CENTER" spacing="10"
                  visible="false" managed="false">
                <TextField fx:id="usernameField"
                           promptText="E-postadress"
                           maxWidth="Infinity"
                           style="-fx-font-size: 15; -fx-padding: 12;
                                  -fx-background-radius: 12; -fx-border-radius: 12;
                                  -fx-border-color: #d6d6d6; -fx-background-color: white;"/>
                <PasswordField fx:id="pinField"
                               promptText="Lösenord"
                               maxWidth="Infinity"
                               style="-fx-font-size: 15; -fx-padding: 12;
                                      -fx-background-radius: 12; -fx-border-radius: 12;
                                      -fx-border-color: #d6d6d6; -fx-background-color: white;"/>
                <Button text="Logga in  →"
                        onAction="#handleCaregiverSubmit"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1a6b3d; -fx-text-fill: white;
                               -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-padding: 13; -fx-background-radius: 14; -fx-cursor: hand;"/>
            </VBox>

        </VBox>

    </children>
</AnchorPane>
