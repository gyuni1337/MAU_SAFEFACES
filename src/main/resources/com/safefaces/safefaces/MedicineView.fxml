<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefWidth="400.0" prefHeight="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.MedicineController">

    <children>
        <ImageView fitWidth="400.0" fitHeight="700.0" preserveRatio="false">
            <image>
                <Image url="@images/medicine_green.png"/>
            </image>
        </ImageView>

        <Button fx:id="backButton"
                layoutX="10.0" layoutY="15.0"
                prefWidth="60.0" prefHeight="60.0"
                onAction="#goBack"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <Button fx:id="listenButton"
                layoutX="330.0" layoutY="15.0"
                prefWidth="60.0" prefHeight="60.0"
                onAction="#readMedicines"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>
    </children>
</AnchorPane>