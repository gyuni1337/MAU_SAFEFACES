<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefWidth="400.0" prefHeight="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.ProfileController">

    <children>

        <!-- Bakgrundsbild: lägg bilden i resources/com.safefaces.safefaces/images/profile_green.png -->
        <ImageView fitWidth="400.0"
                   fitHeight="700.0"
                   preserveRatio="false">
            <image>
                <Image url="@images/user_profile.png"/>
            </image>
        </ImageView>

        <!-- Logga ut-knapp -->
        <Button fx:id="logoutButton"
                layoutX="285.0"
                layoutY="220.0"
                prefWidth="50.0"
                prefHeight="50.0"
                onAction="#logout"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <Button fx:id="informationButton"
                layoutX="34.0" layoutY="280.0"
                prefWidth="332.0" prefHeight="65.0"
                onAction="#openInformation"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>


        <Button fx:id="medicineButton"
                layoutX="34.0" layoutY="355.0"
                prefWidth="332.0" prefHeight="65.0"
                onAction="#openMedicines"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <Button fx:id="healthButton"
                layoutX="34.0" layoutY="425.0"
                prefWidth="332.0" prefHeight="65.0"
                onAction="#openHealth"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>


        <Button fx:id="familyButton"
                layoutX="34.0" layoutY="499.0"
                prefWidth="332.0" prefHeight="65.0"
                onAction="#openFamily"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>
        <!-- Synliga bottenikoner -->
        <ImageView layoutX="55.0" layoutY="637.0" fitWidth="70.0" fitHeight="70.0" preserveRatio="true">
            <image>
                <Image url="@images/reminder.png"/>
            </image>
        </ImageView>

        <ImageView layoutX="172.0" layoutY="637.0" fitWidth="70.0" fitHeight="70.0" preserveRatio="true">
            <image>
                <Image url="@images/home.png"/>
            </image>
        </ImageView>

        <ImageView layoutX="292.0" layoutY="637.0" fitWidth="70.0" fitHeight="70.0" preserveRatio="true">
            <image>
                <Image url="@images/profile.png"/>
            </image>
        </ImageView>

        <Button fx:id="lifeStoryButton"
                layoutX="34.0" layoutY="570.0"
                prefWidth="332.0" prefHeight="55.0"
                onAction="#openLifeStory"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>



        <!-- Bottenmeny: Översikt -->
        <Button fx:id="reminderButton"
                layoutX="35.0"
                layoutY="625.0"
                prefWidth="90.0"
                prefHeight="55.0"
                onAction="#openReminders"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <!-- Bottenmeny: Personer -->
        <Button fx:id="peopleButton"
                layoutX="155.0"
                layoutY="625.0"
                prefWidth="90.0"
                prefHeight="55.0"
                onAction="#openPeople"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <!-- Bottenmeny: Profil -->
        <Button fx:id="profileButton"
                layoutX="275.0"
                layoutY="625.0"
                prefWidth="90.0"
                prefHeight="55.0"
                onAction="#openProfile"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

    </children>
</AnchorPane>