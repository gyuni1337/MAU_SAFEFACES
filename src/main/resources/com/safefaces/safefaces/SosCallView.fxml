<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefWidth="400.0"
            prefHeight="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.SosCallController">

    <children>

        <ImageView fitWidth="400"
                   fitHeight="700"
                   preserveRatio="false">
            <image>
                <Image url="@images/sos_call.png"/>
            </image>
        </ImageView>

        <!-- Osynlig knapp ovanpå AVSLUTA SAMTAL -->
        <Button fx:id="endCallButton"
                layoutX="55"
                layoutY="515"
                prefWidth="290"
                prefHeight="75"
                onAction="#endCall"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

    </children>
</AnchorPane>