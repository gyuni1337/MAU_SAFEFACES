<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefWidth="400.0"
            prefHeight="800.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.SosConfirmController">

    <children>

        <ImageView fitWidth="400"
                   fitHeight="800"
                   preserveRatio="false">
            <image>
                <Image url="@images/SosCallView.png"/>
            </image>
        </ImageView>

        <!-- Ring 112 -->
        <Button fx:id="callButton"
                layoutX="40"
                layoutY="470"
                prefWidth="320"
                prefHeight="75"
                onAction="#startCall"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <!-- Avbryt -->
        <Button fx:id="cancelButton"
                layoutX="40"
                layoutY="575"
                prefWidth="320"
                prefHeight="80"
                onAction="#cancel"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

    </children>
</AnchorPane>