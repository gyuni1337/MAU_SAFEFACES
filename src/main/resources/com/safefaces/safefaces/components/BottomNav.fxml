<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<!-- bottom nav med tre knappar, vänster-ikonen byts ut för vårdgivare i controllern -->
<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.BottomNavController"
      fx:id="navBar"
      alignment="CENTER"
      spacing="55"
      prefHeight="90.0"
      maxWidth="400.0"
      translateY="-27"
      style="-fx-background-color: rgba(255,255,255,0.92);
       -fx-background-radius: 45 45 0 0;
       -fx-padding: 10 25 10 25;
       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 14, 0, 0, -2);">

    <children>
        <StackPane onMouseClicked="#goReminders"
                   HBox.hgrow="ALWAYS"
                   prefHeight="90.0"
                   alignment="CENTER"
                   style="-fx-cursor: hand;">
            <ImageView fx:id="leftNavIcon" fitHeight="70.0" fitWidth="70.0" preserveRatio="true" mouseTransparent="true">
                <image><Image url="@../images/reminder.png"/></image>
            </ImageView>
        </StackPane>

        <StackPane onMouseClicked="#goHome"
                   HBox.hgrow="ALWAYS"
                   prefHeight="90.0"
                   alignment="CENTER"
                   style="-fx-cursor: hand;">
            <ImageView fitHeight="70.0" fitWidth="70.0" preserveRatio="true" mouseTransparent="true">
                <image><Image url="@../images/home.png"/></image>
            </ImageView>
        </StackPane>

        <StackPane onMouseClicked="#goJournal"
                   HBox.hgrow="ALWAYS"
                   prefHeight="70.0"
                   alignment="CENTER"
                   style="-fx-cursor: hand;">
            <ImageView fitHeight="70.0" fitWidth="70.0" preserveRatio="true" mouseTransparent="true">
                <image><Image url="@../images/journal.png"/></image>
            </ImageView>
        </StackPane>
    </children>

</HBox>
