<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.BottomNavController"
      fx:id="navBar"
      alignment="CENTER"
      prefHeight="70.0"
      style="-fx-background-color: white;
             -fx-background-radius: 35;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 16, 0, 0, -2);">
    <padding><Insets left="10" right="10"/></padding>
    <VBox fx:id="remindersTab"
          onMouseClicked="#goReminders"
          alignment="CENTER"
          spacing="4"
          HBox.hgrow="ALWAYS"
          prefWidth="1"
          prefHeight="70.0"
          style="-fx-cursor: hand;">
        <FontIcon fx:id="remindersIcon"
                  iconLiteral="far-bell"
                  iconSize="24"
                  iconColor="#8a8a8a"/>
        <Label fx:id="remindersLabel"
               text="Påminnelser"
               mouseTransparent="true"
               style="-fx-font-size: 11; -fx-text-fill: #8a8a8a;"/>
    </VBox>
    <VBox fx:id="homeTab"
          onMouseClicked="#goHome"
          alignment="CENTER"
          spacing="4"
          HBox.hgrow="ALWAYS"
          prefWidth="1"
          prefHeight="70.0"
          style="-fx-cursor: hand;">
        <FontIcon fx:id="homeIcon"
                  iconLiteral="fas-user-friends"
                  iconSize="24"
                  iconColor="#8a8a8a"/>
        <Label fx:id="homeLabel"
               text="Kontakter"
               mouseTransparent="true"
               style="-fx-font-size: 11; -fx-text-fill: #8a8a8a;"/>
    </VBox>
    <VBox fx:id="journalTab"
          onMouseClicked="#goJournal"
          alignment="CENTER"
          spacing="4"
          HBox.hgrow="ALWAYS"
          prefWidth="1"
          prefHeight="70.0"
          style="-fx-cursor: hand;">
        <FontIcon fx:id="journalIcon"
                  iconLiteral="far-user-circle"
                  iconSize="24"
                  iconColor="#8a8a8a"/>
        <Label fx:id="journalLabel"
               text="Profil"
               mouseTransparent="true"
               style="-fx-font-size: 11; -fx-text-fill: #8a8a8a;"/>
    </VBox>

</HBox>
