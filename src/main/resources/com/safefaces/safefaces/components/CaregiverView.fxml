<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.CaregiverController"
      spacing="0"
      style="-fx-background-color: #f4f4f4;">

    <ScrollPane fitToWidth="true" style="-fx-background: #f4f4f4; -fx-background-color: #f4f4f4;"
                VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="16">
                <padding><Insets top="24" bottom="24" left="20" right="20"/></padding>

                <!-- Header -->
                <Label text="Dina patienter"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3a3a3a;"/>

                <!-- Patient picker -->
                <ComboBox fx:id="patientPicker"
                          promptText="Välj patient"
                          maxWidth="Infinity"
                          style="-fx-font-size: 16px;"/>

                <!-- Add reminder form (hidden until patient selected) -->
                <VBox fx:id="formBox" spacing="12"
                      visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 14;
                             -fx-padding: 16;">

                    <Label text="Ny påminnelse"
                           style="-fx-font-size: 17px; -fx-font-weight: bold;"/>

                    <TextField fx:id="titleField"
                               promptText="Titel"
                               style="-fx-font-size: 15px; -fx-padding: 8;"/>

                    <TextField fx:id="descField"
                               promptText="Beskrivning (valfritt)"
                               style="-fx-font-size: 15px; -fx-padding: 8;"/>

                    <TextField fx:id="timeField"
                               promptText="Tid  (HH:MM)"
                               style="-fx-font-size: 15px; -fx-padding: 8;"/>

                    <ComboBox fx:id="typePicker"
                              promptText="Typ"
                              maxWidth="Infinity"
                              style="-fx-font-size: 15px;"/>

                    <Button text="Lägg till påminnelse"
                            onAction="#handleAddReminder"
                            maxWidth="Infinity"
                            style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                                   -fx-font-size: 15px; -fx-padding: 10; -fx-background-radius: 10;"/>

                    <Label fx:id="formStatus" text="" wrapText="true"
                           style="-fx-font-size: 13px; -fx-text-fill: #e05555;"/>
                </VBox>

                <!-- Current reminders for selected patient -->
                <VBox fx:id="reminderListBox" spacing="10"/>

            </VBox>
        </content>
    </ScrollPane>
</VBox>
