<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<!-- kontaktvyn — rubrik sätts till "Dina patienter" om det är en vårdgivare -->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ContactController"
      alignment="TOP_CENTER"
      spacing="16.0"
      style="-fx-background-color: #f5f6fa;">

    <VBox style="-fx-background-color: white; -fx-padding: 24 24 16 24;">
        <Label fx:id="sectionLabel"
               text="Dina kontakter"
               style="-fx-font-size:26; -fx-font-weight:bold;"/>
        <Label text="Folk du enkelt kan ringa eller lyssna på röstmeddelanden från"
               wrapText="true"
               style="-fx-font-size:13; -fx-text-fill:#888;"/>
    </VBox>

    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                style="-fx-background-color:transparent; -fx-background:transparent;"
                VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="contactListBox" spacing="12">
                <padding>
                    <Insets top="4" bottom="8" left="16" right="16"/>
                </padding>
            </VBox>
        </content>
    </ScrollPane>

</VBox>
