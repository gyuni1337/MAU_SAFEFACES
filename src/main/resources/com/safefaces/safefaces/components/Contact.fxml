<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="400.0"
            prefHeight="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.ContactController">

    <children>

        <ImageView fitWidth="400.0"
                   fitHeight="700.0"
                   preserveRatio="false">
            <image>
                <Image url="@../images/contact_background.png"/>
            </image>
        </ImageView>

        <!-- Osynlig SOS-knapp ovanpå röda plusset -->
        <Button fx:id="sosButton"
                layoutX="305"
                layoutY="175"
                prefWidth="75"
                prefHeight="75"
                onAction="#openSosConfirm"
                style="-fx-background-color: transparent; -fx-cursor: hand;"/>

        <ScrollPane layoutX="30"
                    layoutY="235"
                    prefWidth="340"
                    prefHeight="315"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;
                           -fx-border-color: transparent;">

            <content>
                <VBox fx:id="contactListBox"
                      spacing="12"
                      style="-fx-background-color: transparent;">
                    <padding>
                        <Insets top="10" bottom="10"/>
                    </padding>
                </VBox>
            </content>

        </ScrollPane>

    </children>
</AnchorPane>