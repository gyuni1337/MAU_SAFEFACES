<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ContactController"
      alignment="TOP_CENTER"
      spacing="10"
      style="-fx-background-color: transparent;">

    <padding><Insets top="16" left="16" right="16"/></padding>

    <!-- Title row -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label fx:id="sectionLabel"
                   text="Dina kontakter"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
            <Label text="Här ser du dina närstående och vårdgivare som du kan kontakta."
                   wrapText="true"
                   style="-fx-font-size: 13; -fx-text-fill: #5a7060;"/>
        </VBox>
        <!-- Add button -->
        <VBox onMouseClicked="#handleAddContact"
              alignment="CENTER"
              style="-fx-background-color: #eeeeee;
                     -fx-background-radius: 50;
                     -fx-min-width: 52; -fx-min-height: 52;
                     -fx-pref-width: 52; -fx-pref-height: 52;
                     -fx-cursor: hand;">
            <FontIcon iconLiteral="fas-plus" iconSize="22" iconColor="#e53935"
                      mouseTransparent="true"/>
        </VBox>
    </HBox>

    <!-- White card containing the scrollable contact list -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox fx:id="contactListBox" spacing="0">
                    <padding><Insets top="8" bottom="8" left="12" right="12"/></padding>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>

</VBox>
