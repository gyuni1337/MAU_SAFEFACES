<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ContactController"
      alignment="TOP_CENTER"
      spacing="8.0"
      style="-fx-background-color: transparent;">

    <padding><Insets top="16" left="16" right="16"/></padding>

    <!-- Title row: label left, add button right -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label fx:id="sectionLabel"
               text="Dina kontakter"
               HBox.hgrow="ALWAYS"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
        <Button text="+"
                onAction="#handleAddContact"
                style="-fx-background-color: #e53935;
                       -fx-text-fill: white;
                       -fx-font-size: 22;
                       -fx-font-weight: bold;
                       -fx-background-radius: 50;
                       -fx-min-width: 44;
                       -fx-min-height: 44;
                       -fx-pref-width: 44;
                       -fx-pref-height: 44;
                       -fx-cursor: hand;"/>
    </HBox>

    <Label text="Här ser du dina närstående och vårdgivare som du kan kontakta."
           wrapText="true"
           style="-fx-font-size: 13; -fx-text-fill: #5a7060;"/>

    <!-- White content card -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox fx:id="contactListBox" spacing="12">
                    <padding><Insets top="12" bottom="12" left="12" right="12"/></padding>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>

</VBox>
