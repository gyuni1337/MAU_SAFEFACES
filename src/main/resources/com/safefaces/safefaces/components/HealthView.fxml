<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.HealthController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <content>
        <VBox spacing="0" style="-fx-background-color: transparent;">

            <!-- Header bar -->
            <AnchorPane prefHeight="52" style="-fx-background-color: transparent;">
                <padding><Insets top="6" left="12" right="12"/></padding>
                <HBox onMouseClicked="#goBack" alignment="CENTER"
                      AnchorPane.leftAnchor="12" AnchorPane.topAnchor="6"
                      style="-fx-background-color: rgba(255,255,255,0.75);
                             -fx-background-radius: 50;
                             -fx-min-width: 38; -fx-min-height: 38;
                             -fx-pref-width: 38; -fx-pref-height: 38;
                             -fx-cursor: hand;">
                    <Label text="←" style="-fx-font-size: 18; -fx-text-fill: #1a6b3d; -fx-font-weight: bold;"/>
                </HBox>
                <Label text="Hälsa" alignment="CENTER"
                       AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                       AnchorPane.topAnchor="10"
                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                <HBox alignment="CENTER"
                      AnchorPane.rightAnchor="12" AnchorPane.topAnchor="6"
                      onMouseClicked="#readHealth"
                      style="-fx-background-color: rgba(255,255,255,0.75);
                             -fx-background-radius: 50;
                             -fx-min-width: 38; -fx-min-height: 38;
                             -fx-pref-width: 38; -fx-pref-height: 38;
                             -fx-cursor: hand;">
                    <FontIcon iconLiteral="fas-volume-up" iconSize="16" iconColor="#1a6b3d"/>
                </HBox>
            </AnchorPane>

            <!-- SafeFaces logo (centered, below header) -->
            <VBox alignment="CENTER" spacing="4" style="-fx-padding: 10 0 16 0;">
                <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <Label text="SafeFaces"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
            </VBox>

            <!-- Content -->
            <VBox spacing="14" style="-fx-background-color: transparent;">
                <padding><Insets left="16" right="16" bottom="100"/></padding>

                <!-- Diagnoser -->
                <VBox spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 14 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 10;
                                     -fx-min-width: 36; -fx-min-height: 36;
                                     -fx-pref-width: 36; -fx-pref-height: 36;">
                            <FontIcon iconLiteral="fas-heart" iconSize="18" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Diagnoser"
                               style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-heartbeat" iconSize="16" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Diabetes typ 2" style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #fde8e8; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-heartbeat" iconSize="16" iconColor="#e53935"/>
                        </VBox>
                        <Label text="Högt blodtryck" style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 14 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #fde8e8; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-tint" iconSize="16" iconColor="#e53935"/>
                        </VBox>
                        <Label text="Förhöjda kolesterolvärden" style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                </VBox>

                <!-- Viktigt att komma ihåg -->
                <VBox spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 14 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 10;
                                     -fx-min-width: 36; -fx-min-height: 36;
                                     -fx-pref-width: 36; -fx-pref-height: 36;">
                            <FontIcon iconLiteral="fas-clipboard-list" iconSize="18" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Viktigt att komma ihåg"
                               style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e3f0fc; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-tint" iconSize="16" iconColor="#1565c0"/>
                        </VBox>
                        <Label text="Kontrollera blodsocker varje morgon." style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e3f0fc; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-fill-drip" iconSize="16" iconColor="#1565c0"/>
                        </VBox>
                        <Label text="Drick mycket vatten varje dag." style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 14 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-pills" iconSize="16" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Ta dina mediciner som ordinerat." style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                </VBox>

                <!-- Behandling -->
                <VBox spacing="0"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 14 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #1a6b3d; -fx-background-radius: 50;
                                     -fx-min-width: 36; -fx-min-height: 36;
                                     -fx-pref-width: 36; -fx-pref-height: 36;">
                            <FontIcon iconLiteral="fas-plus" iconSize="18" iconColor="white"/>
                        </VBox>
                        <Label text="Behandling"
                               style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-capsules" iconSize="16" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Daglig medicinering" style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 10 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-walking" iconSize="16" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Promenad minst 30 minuter varje dag" style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 10 16 14 16;">
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #e8f5e9; -fx-background-radius: 8;
                                     -fx-min-width: 32; -fx-min-height: 32; -fx-pref-width: 32; -fx-pref-height: 32;">
                            <FontIcon iconLiteral="fas-apple-alt" iconSize="16" iconColor="#1a6b3d"/>
                        </VBox>
                        <Label text="Ät hälsosamt och balanserat" style="-fx-font-size: 15; -fx-text-fill: #1a3d2e;"/>
                    </HBox>
                </VBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>
