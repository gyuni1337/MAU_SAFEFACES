<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.InformationController"
      spacing="12"
      style="-fx-background-color: transparent;">

    <padding><Insets top="16" left="16" right="16"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Button text="←"
                onAction="#goBack"
                style="-fx-background-color: white; -fx-text-fill: #1a3d2e;
                       -fx-font-size: 18; -fx-font-weight: bold;
                       -fx-background-radius: 50;
                       -fx-min-width: 40; -fx-min-height: 40;
                       -fx-pref-width: 40; -fx-pref-height: 40;
                       -fx-cursor: hand;"/>
        <Label text="Information"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS"
          spacing="12"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
        <Label text="Din information visas här."
               wrapText="true"
               style="-fx-font-size: 15; -fx-text-fill: #555;"/>
        <Button text="🔊  Läs upp"
                onAction="#readInformation"
                style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                       -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-padding: 10; -fx-background-radius: 12; -fx-cursor: hand;"/>
    </VBox>

</VBox>
