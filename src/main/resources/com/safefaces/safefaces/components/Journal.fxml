<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.ProfileController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <content>
        <VBox alignment="TOP_CENTER"
              spacing="14"
              style="-fx-background-color: transparent;">

            <padding><Insets top="24" left="16" right="16" bottom="100"/></padding>
            <ImageView fx:id="profileImage"
                       fitWidth="130" fitHeight="130"
                       preserveRatio="true"/>
            <Label fx:id="nameLabel"
                   text=""
                   style="-fx-font-size: 26; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #1a3d2e;"/>
            <HBox alignment="CENTER" spacing="8">
                <Label fx:id="ageLabel"
                       text=""
                       style="-fx-font-size: 15; -fx-text-fill: #5a7060;"/>
                <Label fx:id="locationSep"
                       text="•"
                       style="-fx-font-size: 15; -fx-text-fill: #5a7060;"/>
                <Label fx:id="locationLabel"
                       text=""
                       style="-fx-font-size: 15; -fx-text-fill: #5a7060;"/>
            </HBox>

            <HBox onMouseClicked="#openInformation"
                  alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 18;
                         -fx-padding: 14; -fx-cursor: hand;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 14;
                             -fx-min-width: 54; -fx-min-height: 54;
                             -fx-pref-width: 54; -fx-pref-height: 54;">
                    <FontIcon iconLiteral="far-id-card" iconSize="26" iconColor="#1a6b3d"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Information"
                           style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #1a3d2e;"/>
                    <Label text="Om dig, utbildning, arbete och intressen"
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #7a9080;"/>
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 50;
                             -fx-min-width: 32; -fx-min-height: 32;
                             -fx-pref-width: 32; -fx-pref-height: 32;">
                    <Label text="›" style="-fx-font-size: 20; -fx-text-fill: #1a6b3d; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5;"/>
                </VBox>
            </HBox>
            <HBox fx:id="medCard"
                  onMouseClicked="#openMedicines"
                  alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 18;
                         -fx-padding: 14; -fx-cursor: hand;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 14;
                             -fx-min-width: 54; -fx-min-height: 54;
                             -fx-pref-width: 54; -fx-pref-height: 54;">
                    <FontIcon iconLiteral="fas-pills" iconSize="26" iconColor="#1a6b3d"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Mediciner"
                           style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #1a3d2e;"/>
                    <Label text="Dina mediciner och när du ska ta dem"
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #7a9080;"/>
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 50;
                             -fx-min-width: 32; -fx-min-height: 32;
                             -fx-pref-width: 32; -fx-pref-height: 32;">
                    <Label text="›" style="-fx-font-size: 20; -fx-text-fill: #1a6b3d; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5;"/>
                </VBox>
            </HBox>
            <HBox fx:id="healthCard"
                  onMouseClicked="#openHealth"
                  alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 18;
                         -fx-padding: 14; -fx-cursor: hand;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 14;
                             -fx-min-width: 54; -fx-min-height: 54;
                             -fx-pref-width: 54; -fx-pref-height: 54;">
                    <FontIcon iconLiteral="fas-heartbeat" iconSize="26" iconColor="#1a6b3d"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Hälsa"
                           style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #1a3d2e;"/>
                    <Label text="Diagnoser, behandlingar och viktiga upplysningar"
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #7a9080;"/>
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 50;
                             -fx-min-width: 32; -fx-min-height: 32;
                             -fx-pref-width: 32; -fx-pref-height: 32;">
                    <Label text="›" style="-fx-font-size: 20; -fx-text-fill: #1a6b3d; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5;"/>
                </VBox>
            </HBox>

            <!-- Waiting on real family/story data before these become clickable. -->
            <HBox fx:id="familyCard"
                  alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: rgba(255,255,255,0.65); -fx-background-radius: 18;
                         -fx-padding: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #eeeeee; -fx-background-radius: 14;
                             -fx-min-width: 54; -fx-min-height: 54;
                             -fx-pref-width: 54; -fx-pref-height: 54;">
                    <FontIcon iconLiteral="fas-users" iconSize="26" iconColor="#9a9a9a"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Familj"
                           style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #8a8a8a;"/>
                    <Label text="Dina närstående och viktig information"
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #aaaaaa;"/>
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #eeeeee; -fx-background-radius: 50;
                             -fx-min-width: 32; -fx-min-height: 32;
                             -fx-pref-width: 32; -fx-pref-height: 32;">
                    <Label text="›" style="-fx-font-size: 20; -fx-text-fill: #9a9a9a; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5;"/>
                </VBox>
            </HBox>
            <HBox fx:id="lifeCard"
                  alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: rgba(255,255,255,0.65); -fx-background-radius: 18;
                         -fx-padding: 14;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #eeeeee; -fx-background-radius: 14;
                             -fx-min-width: 54; -fx-min-height: 54;
                             -fx-pref-width: 54; -fx-pref-height: 54;">
                    <FontIcon iconLiteral="fas-book-open" iconSize="24" iconColor="#9a9a9a"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Livsberättelse"
                           style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #8a8a8a;"/>
                    <Label text="Bilder, minnen och berättelser från ditt liv"
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #aaaaaa;"/>
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #eeeeee; -fx-background-radius: 50;
                             -fx-min-width: 32; -fx-min-height: 32;
                             -fx-pref-width: 32; -fx-pref-height: 32;">
                    <Label text="›" style="-fx-font-size: 20; -fx-text-fill: #9a9a9a; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5;"/>
                </VBox>
            </HBox>
            <HBox onMouseClicked="#handleLogout"
                  alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 18;
                         -fx-padding: 14; -fx-cursor: hand;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <VBox alignment="CENTER"
                      style="-fx-background-color: #fdecea; -fx-background-radius: 14;
                             -fx-min-width: 54; -fx-min-height: 54;
                             -fx-pref-width: 54; -fx-pref-height: 54;">
                    <FontIcon iconLiteral="fas-sign-out-alt" iconSize="24" iconColor="#c0392b"/>
                </VBox>
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Logga ut"
                           style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #c0392b;"/>
                    <Label text="Avsluta sessionen och återgå till inloggning"
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #e07070;"/>
                </VBox>
                <VBox alignment="CENTER"
                      style="-fx-background-color: #fdecea; -fx-background-radius: 50;
                             -fx-min-width: 32; -fx-min-height: 32;
                             -fx-pref-width: 32; -fx-pref-height: 32;">
                    <Label text="›" style="-fx-font-size: 20; -fx-text-fill: #c0392b; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-letter-spacing: 0.5;"/>
                </VBox>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
