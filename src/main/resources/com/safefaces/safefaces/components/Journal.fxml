<?xml version="1.0" encoding="UTF-8"?>

<!-- Imports for layout and UI components -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<!--
    Profile view layout.
    Displays information about the currently logged-in user,
    including profile image, name, age, and additional details.

    Also includes a toggleable section for displaying medications.
    Controlled by ProfileController.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ProfileController"
      alignment="TOP_CENTER"
      spacing="20"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="30" bottom="20" left="24" right="24"/>
    </padding>

    <!-- Profile image of the user (set dynamically in controller) -->
    <ImageView fx:id="profileImage"
               fitWidth="120"
               fitHeight="120"
               preserveRatio="true" />

    <!-- User's full name -->
    <Label fx:id="nameLabel"
           text="Namn"
           style="-fx-font-size: 26px; -fx-font-weight: bold;" />

    <!-- Role badge — shown only for caregivers -->
    <Label fx:id="roleBadge"
           text="Vårdgivare"
           visible="false" managed="false"
           style="-fx-font-size: 13px; -fx-text-fill: white; -fx-background-color: #4a90d9;
                  -fx-background-radius: 20; -fx-padding: 4 14 4 14; -fx-font-weight: bold;" />

    <!-- User's age -->
    <Label fx:id="ageLabel"
           text="Ålder"
           style="-fx-font-size: 18px; -fx-text-fill: #555;" />

    <!-- Caregiver stats — hidden for regular users -->
    <VBox fx:id="caregiverStatsBox"
          visible="false" managed="false"
          spacing="10"
          style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16;">
        <Label fx:id="patientCountLabel"
               style="-fx-font-size: 16px; -fx-text-fill: #333;" />
        <Label fx:id="reminderCountLabel"
               style="-fx-font-size: 16px; -fx-text-fill: #333;" />
    </VBox>

    <!-- Additional information section label -->
    <Label text="Information"
           style="-fx-font-size: 16px; -fx-text-fill: #888;" />

    <!-- Clickable header for medication section -->
    <Label fx:id="medsLabel"
           onMouseClicked="#toggleMeds"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand;">
        Mediciner ◀
    </Label>

    <!-- Hidden container for medications, toggled dynamically -->
    <VBox fx:id="medsBox"
          spacing="10"
          visible="false"
          managed="false"
          style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">

        <!-- Placeholder content, replaced dynamically later -->
        <Label text="Här listas dina mediciner"
               style="-fx-font-size: 16px;" />
    </VBox>

    <!-- User's home location -->
    <Label fx:id="locationLabel"
           wrapText="true"
           style="-fx-font-size: 18px;" />

    <!-- Logout button -->
    <Button text="Logga ut"
            onAction="#handleLogout"
            maxWidth="Infinity"
            style="-fx-background-color: #e05555; -fx-text-fill: white;
                   -fx-font-size: 16px; -fx-font-weight: bold;
                   -fx-padding: 12; -fx-background-radius: 14; -fx-cursor: hand;" />
</VBox>
