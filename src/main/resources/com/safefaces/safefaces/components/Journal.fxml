<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ProfileController"
      alignment="TOP_CENTER"
      spacing="20"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="30" bottom="20" left="24" right="24"/>
    </padding>

    <!-- Profile header: avatar left, name + role badge right -->
    <HBox spacing="20" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;">

        <ImageView fx:id="profileImage"
                   fitWidth="90"
                   fitHeight="90"
                   preserveRatio="true" />

        <VBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="nameLabel"
                   text="Namn"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />

            <!-- Role badge — text and color set dynamically -->
            <Label fx:id="roleBadge"
                   text=""
                   style="-fx-font-size: 13px; -fx-text-fill: white;
                          -fx-background-radius: 20; -fx-padding: 4 14 4 14;
                          -fx-font-weight: bold;" />
        </VBox>
    </HBox>

    <!-- Information section header -->
    <Label text="Information"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3a3a3a;" />

    <!-- Info card: age, location, and caregiver stats -->
    <VBox spacing="12"
          style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 18;">

        <Label fx:id="ageLabel"
               text="Ålder"
               style="-fx-font-size: 16px; -fx-text-fill: #555;" />

        <Label fx:id="locationLabel"
               wrapText="true"
               style="-fx-font-size: 16px; -fx-text-fill: #555;" />

        <!-- Caregiver-only stats -->
        <VBox fx:id="caregiverStatsBox"
              visible="false" managed="false"
              spacing="8">
            <Label fx:id="patientCountLabel"
                   style="-fx-font-size: 16px; -fx-text-fill: #333;" />
            <Label fx:id="reminderCountLabel"
                   style="-fx-font-size: 16px; -fx-text-fill: #333;" />
        </VBox>
    </VBox>

    <!-- Clickable header for medication section -->
    <Label fx:id="medsLabel"
           onMouseClicked="#toggleMeds"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand;">
        Mediciner ◀
    </Label>

    <!-- Hidden container for medications, toggled dynamically -->
    <VBox fx:id="medsBox"
          spacing="10"
          visible="false"
          managed="false"
          style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">
        <Label text="Här listas dina mediciner"
               style="-fx-font-size: 16px;" />
    </VBox>

    <!-- Logout button -->
    <Button text="Logga ut"
            onAction="#handleLogout"
            maxWidth="Infinity"
            style="-fx-background-color: #e05555; -fx-text-fill: white;
                   -fx-font-size: 16px; -fx-font-weight: bold;
                   -fx-padding: 12; -fx-background-radius: 14; -fx-cursor: hand;" />
</VBox>
