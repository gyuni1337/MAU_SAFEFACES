<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.ProfileController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <content>
        <VBox alignment="TOP_CENTER"
              spacing="12"
              style="-fx-background-color: transparent;">

            <padding><Insets top="16" left="16" right="16" bottom="80"/></padding>

            <!-- Profile card -->
            <VBox style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-padding: 16;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <ImageView fx:id="profileImage"
                               fitWidth="72" fitHeight="72"
                               preserveRatio="true"/>
                    <VBox spacing="6" alignment="CENTER_LEFT">
                        <Label fx:id="nameLabel"
                               text="Namn"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                        <Label fx:id="roleBadge"
                               text=""
                               style="-fx-font-size: 12; -fx-text-fill: white;
                                      -fx-background-radius: 20; -fx-padding: 3 12 3 12;
                                      -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Info card -->
            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-padding: 16;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <Label text="Information"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                <Label fx:id="ageLabel"
                       text=""
                       style="-fx-font-size: 15; -fx-text-fill: #555;"/>
                <Label fx:id="locationLabel"
                       wrapText="true"
                       style="-fx-font-size: 15; -fx-text-fill: #555;"/>
                <VBox fx:id="caregiverStatsBox"
                      visible="false" managed="false" spacing="6">
                    <Label fx:id="patientCountLabel"
                           style="-fx-font-size: 15; -fx-text-fill: #333;"/>
                    <Label fx:id="reminderCountLabel"
                           style="-fx-font-size: 15; -fx-text-fill: #333;"/>
                </VBox>
            </VBox>

            <!-- Medications card (collapsible) -->
            <VBox style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT"
                      onMouseClicked="#toggleMeds"
                      style="-fx-cursor: hand; -fx-padding: 14 16 14 16;">
                    <Label fx:id="medsLabel"
                           text="Mediciner ▶"
                           HBox.hgrow="ALWAYS"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                </HBox>
                <VBox fx:id="medsBox"
                      spacing="8"
                      visible="false" managed="false"
                      style="-fx-padding: 0 16 14 16;">
                    <Label text="Här listas dina mediciner"
                           style="-fx-font-size: 14; -fx-text-fill: #555;"/>
                </VBox>
            </VBox>

            <!-- Features navigation -->
            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-padding: 14 16 14 16;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                <Label text="Utforska"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a3d2e;"/>
                <Button text="Information"
                        onAction="#openInformation"
                        maxWidth="Infinity"
                        style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                               -fx-font-size: 15; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand;"/>
                <Button text="Mediciner"
                        onAction="#openMedicines"
                        maxWidth="Infinity"
                        style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                               -fx-font-size: 15; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand;"/>
                <Button text="Hälsa"
                        onAction="#openHealth"
                        maxWidth="Infinity"
                        style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                               -fx-font-size: 15; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand;"/>
                <Button text="Familj"
                        onAction="#openFamily"
                        maxWidth="Infinity"
                        style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                               -fx-font-size: 15; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand;"/>
                <Button text="Livsberättelse"
                        onAction="#openLifeStory"
                        maxWidth="Infinity"
                        style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                               -fx-font-size: 15; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand;"/>
                <Button text="SOS – Ring 112"
                        onAction="#openSos"
                        maxWidth="Infinity"
                        style="-fx-background-color: #fde8e8; -fx-text-fill: #c62828;
                               -fx-font-size: 15; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 12; -fx-cursor: hand;"/>
            </VBox>

            <!-- Logout -->
            <Button text="Logga ut"
                    onAction="#handleLogout"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e05555; -fx-text-fill: white;
                           -fx-font-size: 16; -fx-font-weight: bold;
                           -fx-padding: 12; -fx-background-radius: 14; -fx-cursor: hand;"/>

        </VBox>
    </content>
</ScrollPane>
