<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.LifeStoryController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <content>
        <VBox spacing="0" style="-fx-background-color: transparent;">

            <HBox alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color: transparent; -fx-padding: 10 12 6 12;">
                <VBox onMouseClicked="#goBack" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.75);
                             -fx-background-radius: 50;
                             -fx-min-width: 38; -fx-min-height: 38;
                             -fx-pref-width: 38; -fx-pref-height: 38;
                             -fx-cursor: hand;">
                    <Label text="←" mouseTransparent="true"
                           style="-fx-font-size: 18; -fx-text-fill: #1a6b3d;
                                  -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Livsberättelse"
                       style="-fx-font-size: 22; -fx-font-family: 'Helvetica Neue';
                              -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox onMouseClicked="#readLifeStory" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.75);
                             -fx-background-radius: 50;
                             -fx-min-width: 38; -fx-min-height: 38;
                             -fx-pref-width: 38; -fx-pref-height: 38;
                             -fx-cursor: hand;">
                    <FontIcon iconLiteral="fas-volume-up" iconSize="16" iconColor="#1a6b3d"
                              mouseTransparent="true"/>
                </VBox>
            </HBox>

            <VBox spacing="14" style="-fx-background-color: transparent;">
                <padding><Insets top="10" left="16" right="16" bottom="100"/></padding>

                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-padding: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <ImageView fitWidth="344" fitHeight="215" preserveRatio="false" smooth="true">
                        <image><Image url="@../images/story1.jpg"/></image>
                    </ImageView>
                    <Label text="Minnen från förr"
                           style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue';
                                  -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
                </VBox>

                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-padding: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <ImageView fitWidth="344" fitHeight="215" preserveRatio="false" smooth="true">
                        <image><Image url="@../images/story2.jpg"/></image>
                    </ImageView>
                    <Label text="Familj och vänner"
                           style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue';
                                  -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
                </VBox>

                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-padding: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <ImageView fitWidth="344" fitHeight="215" preserveRatio="false" smooth="true">
                        <image><Image url="@../images/story3.jpg"/></image>
                    </ImageView>
                    <Label text="Viktiga platser"
                           style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue';
                                  -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
                </VBox>

                <VBox spacing="8"
                      style="-fx-background-color: white; -fx-background-radius: 18;
                             -fx-padding: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                    <ImageView fitWidth="344" fitHeight="215" preserveRatio="false" smooth="true">
                        <image><Image url="@../images/story5.jpg"/></image>
                    </ImageView>
                    <Label text="Ögonblick att minnas"
                           style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue';
                                  -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
                </VBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>
