<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.MedicineController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <content>
        <VBox spacing="0" style="-fx-background-color: transparent;">
            <HBox alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color: transparent; -fx-padding: 10 12 6 12;">
                <VBox onMouseClicked="#goBack" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.75);
                             -fx-background-radius: 50;
                             -fx-min-width: 38; -fx-min-height: 38;
                             -fx-pref-width: 38; -fx-pref-height: 38;
                             -fx-cursor: hand;">
                    <Label text="←" mouseTransparent="true"
                           style="-fx-font-size: 18; -fx-text-fill: #1a6b3d; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600;"/>
                </VBox>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
                <Label text="Mediciner"
                       style="-fx-font-size: 22; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
                <VBox onMouseClicked="#readMedicines" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.75);
                             -fx-background-radius: 50;
                             -fx-min-width: 38; -fx-min-height: 38;
                             -fx-pref-width: 38; -fx-pref-height: 38;
                             -fx-cursor: hand;">
                    <FontIcon iconLiteral="fas-volume-up" iconSize="16" iconColor="#1a6b3d"
                              mouseTransparent="true"/>
                </VBox>
            </HBox>
            <VBox spacing="16" style="-fx-background-color: transparent;">
                <padding><Insets top="10" left="16" right="16" bottom="100"/></padding>
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 14;
                             -fx-padding: 14;">
                    <FontIcon iconLiteral="fas-info-circle" iconSize="22" iconColor="#1a6b3d"/>
                    <Label text="Ta dina mediciner enligt tiderna&#10;för att må bra."
                           wrapText="true"
                           style="-fx-font-size: 14; -fx-text-fill: #1a3d2e;"/>
                </HBox>
                <VBox fx:id="morningSection" spacing="0" visible="false" managed="false">
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-padding: 4 0 8 0;">
                        <FontIcon iconLiteral="fas-sun" iconSize="22" iconColor="#f59e0b"/>
                        <Label text="Morgon"
                               style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="morningTime" text="08:00"
                               style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a6b3d;"/>
                    </HBox>
                    <VBox fx:id="morningBox" spacing="0"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);"/>
                </VBox>
                <VBox fx:id="lunchSection" spacing="0" visible="false" managed="false">
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-padding: 4 0 8 0;">
                        <FontIcon iconLiteral="fas-sun" iconSize="22" iconColor="#f59e0b"/>
                        <Label text="Lunch"
                               style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lunchTime" text="12:00"
                               style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a6b3d;"/>
                    </HBox>
                    <VBox fx:id="lunchBox" spacing="0"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);"/>
                </VBox>
                <VBox fx:id="eveningSection" spacing="0" visible="false" managed="false">
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-padding: 4 0 8 0;">
                        <FontIcon iconLiteral="fas-moon" iconSize="22" iconColor="#7c3aed"/>
                        <Label text="Kväll"
                               style="-fx-font-size: 17; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="eveningTime" text="20:00"
                               style="-fx-font-size: 16; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a6b3d;"/>
                    </HBox>
                    <VBox fx:id="eveningBox" spacing="0"
                          style="-fx-background-color: white; -fx-background-radius: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);"/>
                </VBox>
                <Label fx:id="emptyLabel" text="Inga mediciner registrerade."
                       visible="false" managed="false"
                       style="-fx-font-size: 15; -fx-text-fill: #8aab90;"/>
                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: #e8f5e9; -fx-background-radius: 14;
                             -fx-padding: 14;">
                    <FontIcon iconLiteral="fas-fill-drip" iconSize="20" iconColor="#1a6b3d"/>
                    <Label text="Drick ett glas vatten till varje medicin."
                           wrapText="true"
                           style="-fx-font-size: 14; -fx-text-fill: #1a3d2e;"/>
                </HBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>
