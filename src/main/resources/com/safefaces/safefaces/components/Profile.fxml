<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ProfileController"
      alignment="TOP_CENTER"
      spacing="20"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="30" bottom="20" left="24" right="24"/>
    </padding>

    <!-- Profilbild -->
    <ImageView fx:id="profileImage"
               fitWidth="120"
               fitHeight="120"
               preserveRatio="true" />

    <!-- Namn -->
    <Label fx:id="nameLabel"
           text="Namn"
           style="-fx-font-size: 26px; -fx-font-weight: bold;" />

    <!-- Ålder -->
    <Label fx:id="ageLabel"
           text="Ålder"
           style="-fx-font-size: 18px; -fx-text-fill: #555;" />

    <!-- Ev info -->
    <Label text="Information"
           style="-fx-font-size: 16px; -fx-text-fill: #888;" />


    <!-- Rubrik för medicin -->
    <Label fx:id="medsLabel"
           onMouseClicked="#toggleMeds"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand;">
        Mediciner ◀
    </Label>

    <!-- Medicinlistan som är dold från början -->
    <VBox fx:id="medsBox"
          spacing="10"
          visible="false"
          managed="false"
          style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10;">

        <!-- Tillfällig text, ersätts senare med riktiga mediciner -->
        <Label text="Här listas dina mediciner"
               style="-fx-font-size: 16px;" />
    </VBox>

    <!-- Minne/hjälptext, ersätts senare -->
    <Label text="Du är hemma i Malmö"
           wrapText="true"
           style="-fx-font-size: 18px;" />
</VBox>
