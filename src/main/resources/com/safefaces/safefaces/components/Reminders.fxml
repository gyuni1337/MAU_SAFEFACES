<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ReminderController"
      alignment="TOP_CENTER"
      spacing="8.0"
      style="-fx-background-color: transparent;">

    <padding><Insets top="16" left="16" right="16"/></padding>

    <Label text="Här är din reminderlista"
           style="-fx-font-size: 22; -fx-font-family: 'Helvetica Neue'; -fx-font-weight: 600; -fx-text-fill: #1a3d2e;"/>
    <Label text="Här ser du saker som du måste fixa eller komma ihåg."
           wrapText="true"
           style="-fx-font-size: 13; -fx-text-fill: #5a7060;"/>

    <!-- White content card -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);">
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox fx:id="reminderListBox" spacing="12"
                      style="-fx-background-color: transparent;">
                    <padding><Insets top="12" bottom="80" left="12" right="12"/></padding>
                </VBox>
            </content>
        </ScrollPane>
    </VBox>

</VBox>
