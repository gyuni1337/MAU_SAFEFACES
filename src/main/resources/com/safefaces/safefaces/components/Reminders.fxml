<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.safefaces.safefaces.Javafx.Controller.ReminderController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">
    <content>
        <VBox spacing="14"
              style="-fx-background-color: transparent;">
            <padding><Insets top="28" left="16" right="16" bottom="100"/></padding>

            <Label text="Påminnelser"
                   style="-fx-font-size: 28; -fx-font-family: 'Helvetica Neue';
                          -fx-font-weight: 600; -fx-letter-spacing: 0.5; -fx-text-fill: #1a3d2e;"/>
            <Label text="Saker du måste fixa eller komma ihåg."
                   wrapText="true"
                   style="-fx-font-size: 14; -fx-text-fill: #5a7060;"/>

            <VBox fx:id="reminderListBox" spacing="12"/>
        </VBox>
    </content>
</ScrollPane>
