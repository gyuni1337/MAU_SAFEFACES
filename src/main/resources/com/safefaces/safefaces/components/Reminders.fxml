<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.ScrollPane?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.ReminderController"
      spacing="0"
      style ="-fx-background-color:#f5f6fa;">
<VBox style="-fx-background-color: white;-fx-padding: 24 24 16 24;">
    <Label text="Påminnelser"
           style="-fx-font-size:26;-fx-font-weight:bold;"/>
    <Label text="Dina aktiva påminnelser"
           style="-fx-font-size:13;-fx-text-fill:#888;"/>
</VBox>

    <ScrollPane fitToWidth="true"
                style="-fx-background-color:transparent;-fx-background-color: transparent;"
                VBox.vgrow="ALWAYS">
        <VBox fx:id="reminderListBox"
              spacing="12"
              style="-fx-background-color:#f5f6fa;">
             <padding>
                 <Insets top="16"
                    bottom="80"
                    left="16"
                    right="16"/>
             </padding>
        </VBox>

    </ScrollPane>

</VBox>
