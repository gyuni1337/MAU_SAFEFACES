<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.safefaces.safefaces.Javafx.Controller.SosConfirmController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: transparent;">

    <padding><Insets top="40" left="24" right="24"/></padding>

    <VBox alignment="CENTER"
          spacing="24"
          style="-fx-background-color: white;
                 -fx-background-radius: 24;
                 -fx-padding: 40;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 16, 0, 0, 4);">

        <Label text="🚨"
               style="-fx-font-size: 60;"/>
        <Label text="Vill du ringa 112?"
               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>
        <Label text="Du är på väg att ringa nödnumret.\nÄr du säker?"
               wrapText="true"
               style="-fx-font-size: 15; -fx-text-fill: #555; -fx-text-alignment: center;"/>

        <Button text="Ring 112"
                onAction="#startCall"
                maxWidth="Infinity"
                style="-fx-background-color: #e53935; -fx-text-fill: white;
                       -fx-font-size: 18; -fx-font-weight: bold;
                       -fx-padding: 16; -fx-background-radius: 14; -fx-cursor: hand;"/>

        <Button text="Avbryt"
                onAction="#cancel"
                maxWidth="Infinity"
                style="-fx-background-color: #f0f7f2; -fx-text-fill: #1a3d2e;
                       -fx-font-size: 16; -fx-font-weight: bold;
                       -fx-padding: 14; -fx-background-radius: 14; -fx-cursor: hand;"/>
    </VBox>

</VBox>
