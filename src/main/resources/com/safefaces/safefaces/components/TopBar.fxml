<?xml version="1.0" encoding="UTF-8"?>

<!-- Imports for layout, controls, and images -->
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>

<!--
    Header component for the application.
    Displays the application name ("SafeFaces") together with a logo.

    This component is used as a static UI element and does not
    require a controller.
-->
<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER"
      spacing="15.0"
      style="-fx-background-color: transparent;">

    <children>
        <!-- Application title -->
        <Label text="SafeFaces" style="-fx-text-fill: #3a3a3a;">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>

        <!-- Application logo -->
        <ImageView fitHeight="24.0" fitWidth="21.0" preserveRatio="true">
            <image>
                <Image url="@../images/logo.png"/>
            </image>
        </ImageView>
    </children>

</HBox>