<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="70.0" prefWidth="400.0"
            style="-fx-background-color: transparent;">

    <!-- Centered: logo icon + app name -->
    <HBox alignment="CENTER"
          spacing="10"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          mouseTransparent="true">
<!--        <ImageView fitHeight="32.0" fitWidth="32.0" preserveRatio="true">-->
<!--            <image><Image url="@../images/logo.png"/></image>-->
<!--        </ImageView>-->
<!--        <Label text="SafeFaces">-->
<!--            <font><Font name="System Bold" size="22.0"/></font>-->
<!--            <style>-fx-text-fill: #1a6b3d;</style>-->
<!--        </Label>-->
    </HBox>

    <!-- Right-anchored: sound button -->
    <Button text="🔊"
            AnchorPane.topAnchor="15" AnchorPane.rightAnchor="16"
            style="-fx-background-color: rgba(255,255,255,0.75);
                   -fx-text-fill: #1a6b3d;
                   -fx-font-size: 16;
                   -fx-background-radius: 50;
                   -fx-min-width: 40; -fx-min-height: 40;
                   -fx-pref-width: 40; -fx-pref-height: 40;
                   -fx-cursor: hand;"/>

</AnchorPane>
